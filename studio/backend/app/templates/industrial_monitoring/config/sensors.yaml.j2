# Generated by Black Dragon Studio -- do not hand-edit thresholds without
# updating system_spec.json, they will drift out of sync.
sensors:
{% for s in spec.sensors %}
  - id: {{ s.id }}
    type: {{ s.type }}
    unit: {{ s.unit }}
    sample_rate_hz: {{ s.sample_rate_hz }}
    normal_range: [{{ s.normal_range[0] }}, {{ s.normal_range[1] }}]
    warning_threshold: {{ s.warning_threshold }}
    critical_threshold: {{ s.critical_threshold }}
{% endfor %}
