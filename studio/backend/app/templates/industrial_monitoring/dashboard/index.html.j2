<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8" />
<title>{{ spec.project.name }} -- Dashboard</title>
<style>
  body { font-family: -apple-system, Segoe UI, Roboto, sans-serif; margin: 0; background: #0b0e14; color: #e6e6e6; }
  header { padding: 20px 28px; border-bottom: 1px solid #222; }
  header h1 { margin: 0; font-size: 20px; }
  header p { margin: 4px 0 0; color: #999; font-size: 13px; }
  .badge { display: inline-block; padding: 2px 8px; border-radius: 10px; background: #3a2a00; color: #ffb020; font-size: 11px; margin-left: 8px; }
  main { padding: 24px 28px; display: grid; grid-template-columns: 1fr 1fr; gap: 20px; }
  .card { background: #131722; border: 1px solid #222; border-radius: 8px; padding: 16px; }
  .card h2 { font-size: 14px; margin: 0 0 10px; color: #aaa; text-transform: uppercase; letter-spacing: .04em; }
  select, button { background: #1c2230; color: #eee; border: 1px solid #333; border-radius: 6px; padding: 6px 10px; }
  table { width: 100%; border-collapse: collapse; font-size: 12px; }
  td, th { padding: 4px 6px; border-bottom: 1px solid #1e2430; text-align: left; }
  .critical { color: #ff5c5c; font-weight: 600; }
  .warning { color: #ffb020; font-weight: 600; }
  .info { color: #6ee7b7; }
  canvas { width: 100%; height: 220px; }
  .full { grid-column: 1 / -1; }
</style>
</head>
<body>
<header>
  <h1>{{ spec.project.name }} <span class="badge">SIMULATED DATA</span></h1>
  <p>{{ spec.project.description }}</p>
</header>
<main>
  <div class="card full">
    <h2>Load simulation output</h2>
    <p style="color:#999; font-size:12px;">
      Run <code>python simulation/simulator.py</code> then <code>python -m http.server</code>
      from the project root, or select the JSON file below.
    </p>
    <input type="file" id="fileInput" accept="application/json" />
  </div>
  <div class="card full">
    <h2>Sensor trace</h2>
    <canvas id="chart"></canvas>
  </div>
  <div class="card full">
    <h2>Event timeline</h2>
    <table id="timelineTable">
      <thead><tr><th>Step</th><th>Rule</th><th>Severity</th><th>Mode</th><th>Action</th><th>Reason</th></tr></thead>
      <tbody></tbody>
    </table>
  </div>
</main>
<script>
const fileInput = document.getElementById('fileInput');
const tbody = document.querySelector('#timelineTable tbody');
const canvas = document.getElementById('chart');
const ctx = canvas.getContext('2d');

function render(data) {
  const scenarioKey = Object.keys(data)[0];
  const timeline = data[scenarioKey].timeline || data.timeline || [];
  tbody.innerHTML = '';
  timeline.forEach(ev => {
    const tr = document.createElement('tr');
    const sevClass = ev.severity === 'critical' ? 'critical' : (ev.severity === 'warning' ? 'warning' : 'info');
    tr.innerHTML = `<td>${ev.step}</td><td>${ev.fired_rule || '-'}</td><td class="${sevClass}">${ev.severity}</td><td>${ev.mode}</td><td>${ev.action}</td><td>${ev.reason}</td>`;
    tbody.appendChild(tr);
  });
  drawChart(timeline);
}

function drawChart(timeline) {
  canvas.width = canvas.clientWidth * 2;
  canvas.height = 440;
  ctx.clearRect(0, 0, canvas.width, canvas.height);
  if (!timeline.length) return;
  const sensorIds = Object.keys(timeline[0].readings || {});
  const colors = ['#6ee7b7', '#60a5fa', '#ffb020', '#ff5c5c', '#c084fc'];
  sensorIds.forEach((sid, i) => {
    const values = timeline.map(e => e.readings[sid]);
    const min = Math.min(...values), max = Math.max(...values);
    ctx.strokeStyle = colors[i % colors.length];
    ctx.lineWidth = 3;
    ctx.beginPath();
    values.forEach((v, idx) => {
      const x = (idx / (values.length - 1)) * canvas.width;
      const y = canvas.height - ((v - min) / Math.max(max - min, 1e-6)) * (canvas.height - 20) - 10;
      idx === 0 ? ctx.moveTo(x, y) : ctx.lineTo(x, y);
    });
    ctx.stroke();
  });
}

fileInput.addEventListener('change', (e) => {
  const file = e.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = () => render(JSON.parse(reader.result));
  reader.readAsText(file);
});

// try auto-loading outputs/simulation_results.json when served over http
fetch('../outputs/simulation_results.json').then(r => r.ok ? r.json() : null).then(d => { if (d) render(d); }).catch(() => {});
</script>
</body>
</html>
