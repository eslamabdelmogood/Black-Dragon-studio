# Optional: enables the LLM-backed Specification Agent (GPT-5.6). If unset,
# Black Dragon Studio automatically falls back to the deterministic
# heuristic extractor, which is what the required demonstration prompt in
# the constitution is validated against.
OPENAI_API_KEY=
SPEC_AGENT_MODEL=gpt-5.6

# Where generated projects and exports are stored.
BDS_WORKSPACE_ROOT=./workspace

# Safety limits
BDS_SUBPROCESS_TIMEOUT=60
BDS_MAX_ZIP_BYTES=52428800
